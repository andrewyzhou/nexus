# Copy to /home/ubuntu/nexus/.env on the server and fill in real values.
# This file is READ by the nexus.service systemd unit.

# Postgres connection string. For the on-EC2 Docker postgres this is:
#   postgresql://nexus:nexus@127.0.0.1:5433/corporate_data
# For RDS, use the RDS endpoint + credentials.
DATABASE_URL=postgresql://nexus:nexus@127.0.0.1:5433/corporate_data

# Restrict browser CORS to the production origin. "*" is fine in dev only.
NEXUS_CORS_ORIGINS=https://ipick.ai

# API mount point — leave as the default unless you're running Nexus solo
# (no nginx prefix), in which case set to "" and adjust nginx accordingly.
NEXUS_API_PREFIX=/nexus/api

# ── Firebase auth gate ─────────────────────────────────────────────────
# Set to 1 to require a verified Firebase ID token on every /nexus/api/*
# request. Leave unset (or "0") for local dev without auth.
NEXUS_REQUIRE_AUTH=1

# Base64-encoded Firebase service account JSON (same format iPick uses).
# Copy this value from the iPick gunicorn environment, NOT from a file.
FIREBASE_CREDENTIALS=

# Public Firebase client config (safe to expose — the actual auth is
# enforced by Firebase server-side). Frontend reads these from
# /nexus/api/config at load time.
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=

# Where to redirect an unauthenticated visitor. iPick's login route lives
# at /login and accepts ?next=<url> for post-login return.
NEXUS_LOGIN_URL=https://www.ipick.ai/login

# Optional: AWS creds for ticker_track.json + suppliers.json + subsidiaries.json
# auto-download at seed time. Not needed if the EC2 instance has an IAM
# role that already allows s3:GetObject on ipickai-storage.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-west-2
