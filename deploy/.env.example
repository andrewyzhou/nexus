# Copy to /home/ubuntu/nexus/.env on the server and fill in real values.
# This file is READ by the nexus.service systemd unit.

# Postgres connection string. For the on-EC2 Docker postgres this is:
#   postgresql://nexus:nexus@127.0.0.1:5433/corporate_data
# For RDS, use the RDS endpoint + credentials.
DATABASE_URL=postgresql://nexus:nexus@127.0.0.1:5433/corporate_data

# Restrict browser CORS to the production origin. "*" is fine in dev only.
NEXUS_CORS_ORIGINS=https://ipick.ai

# API mount point — leave as the default unless you're running Nexus solo
# (no nginx prefix), in which case set to "" and adjust nginx accordingly.
NEXUS_API_PREFIX=/nexus/api

# Optional: AWS creds for the ticker_track.json auto-download in seed_demo.py.
# If set, the seeder tries `aws s3 cp ...` or boto3 on first run.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-west-2
